{
    "name": "crowbot/cli",
    "description": "Standalone Crow CLI for reading events, listening for handoffs, and fetching implementation plans.",
    "type": "project",
    "license": "MIT",
    "bin": [
        "builds/crow"
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "illuminate/http": "^12.17",
        "laravel-zero/framework": "^12.1",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
