{
    "name": "crowbot/listen",
    "description": "Artisan commands for reading and listening to Crow developer handoff events.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Crow\\Listen\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Crow\\Listen\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Crow\\Listen\\CrowListenServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
